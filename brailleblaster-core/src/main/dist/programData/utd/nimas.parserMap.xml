	<!-- tables -->

	<!--
		Linear table transcriber note (tabletn) — placed as a SIBLING before <table>,
		NOT inside <table>. The three nested elements produce exactly the expected BBX
		subtree with no fixer work required for the TABLETN container itself.

		XML structure expected in source document:
		  <tabletn class="linear">
		    <tabletn-note><trans-note>Columns follow...</trans-note></tabletn-note>
		    <colheads><colhead>A</colhead>: <colhead>B</colhead>; ... <colhead>Z</colhead>.</colheads>
		  </tabletn>
		  <table>  (data rows only, no header row)

		Produces BBX:
		  CONTAINER TABLETN
		    BLOCK STYLE "7-5"
		      INLINE EMPHASIS TRANS_NOTE  "Columns follow..."
		    BLOCK STYLE "1-3"
		      SPAN OTHER "A"  [text ": "]  SPAN OTHER "B"  [text "; "] ... SPAN OTHER "Z"  [text "."]
		  CONTAINER TABLE (format="linear" set by TableImportFixer when it finds the TABLETN sibling)
	-->

	<!-- <tabletn class="linear"> → CONTAINER TABLETN (sibling of table, NOT inside table) -->
	<entry>
		<matcher type="org.brailleblaster.utd.matchers.NodeAttributeMatcher"
				 nodeName="bai-tabletn"
				 selfAttribName="format"
				 selfAttribValue="linear"
		/>
		<parser type="org.brailleblaster.bbx.parsers.BBXImportParser"
				containerType="TABLETN"
		/>
	</entry>
	<entry>
		<matcher type="org.brailleblaster.utd.matchers.NodeAttributeMatcher"
				 nodeName="bai-tabletn"
				 selfAttribName="format"
				 selfAttribValue="simple"
		/>
		<parser type="org.brailleblaster.bbx.parsers.BBXImportParser"
				containerType="TABLETN"
		/>
	</entry>
	<entry>
		<matcher type="org.brailleblaster.utd.matchers.NodeAttributeMatcher"
				 nodeName="bai-tabletn"
				 selfAttribName="format"
				 selfAttribValue="stairstep"
		/>
		<parser type="org.brailleblaster.bbx.parsers.BBXImportParser"
				containerType="TABLETN"
		/>
	</entry>
	<entry>
		<matcher type="org.brailleblaster.utd.matchers.NodeAttributeMatcher"
				 nodeName="bai-tabletn"
				 selfAttribName="format"
				 selfAttribValue="listed"
		/>
		<parser type="org.brailleblaster.bbx.parsers.BBXImportParser"
				containerType="TABLETN"
		/>
	</entry>

	<!-- <tabletn-note> inside <tabletn> → BLOCK STYLE "7-5" -->
	<entry>
		<matcher type="org.brailleblaster.utd.matchers.AndMatcher">
			<matcher type="org.brailleblaster.bbx.utd.AncestorMatcher">
				<matcher type="org.brailleblaster.utd.matchers.NodeNameMatcher"
						 nodeName="bai-tabletn"
				/>
			</matcher>
			<matcher type="org.brailleblaster.utd.matchers.NodeNameMatcher"
					 nodeName="bai-tabletn-note"
			/>
		</matcher>
		<parser type="org.brailleblaster.bbx.parsers.BBXImportParser"
				blockType="STYLE"
				styleName="7-5"
		/>
	</entry>

	<!-- <trans-note> inside <tabletn> → INLINE EMPHASIS TRANS_NOTE -->
	<entry>
		<matcher type="org.brailleblaster.utd.matchers.AndMatcher">
			<matcher type="org.brailleblaster.bbx.utd.AncestorMatcher">
				<matcher type="org.brailleblaster.utd.matchers.NodeNameMatcher"
						 nodeName="bai-tabletn"
				/>
			</matcher>
			<matcher type="org.brailleblaster.utd.matchers.NodeNameMatcher"
					 nodeName="bai-trans-note"
			/>
		</matcher>
		<parser type="org.brailleblaster.bbx.parsers.BBXImportParser"
				emphasisType="TRANS_NOTE"
		/>
	</entry>

	<!-- <colheads> inside <tabletn> → BLOCK STYLE "1-3"
	     Text nodes between <colhead> elements (": ", "; ", ".")
	     become raw text nodes directly inside this BLOCK-->
	<entry>
		<matcher type="org.brailleblaster.utd.matchers.AndMatcher">
			<matcher type="org.brailleblaster.bbx.utd.AncestorMatcher">
				<matcher type="org.brailleblaster.utd.matchers.NodeNameMatcher"
						 nodeName="bai-tabletn"
				/>
			</matcher>
			<matcher type="org.brailleblaster.utd.matchers.NodeNameMatcher"
					 nodeName="bai-colheads"
			/>
		</matcher>
		<parser type="org.brailleblaster.bbx.parsers.BBXImportParser"
				blockType="STYLE"
				styleName="1-3"
		/>
	</entry>

	<!-- <colhead> inside <tabletn> → SPAN OTHER -->
	<entry>
